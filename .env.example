# ─── Brevo (waitlist B2C + notification leads pro) ───────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=your_brevo_list_id_here

# ─── Leads pro : notification à l'équipe (email = son déclencheur) ─────────────
# Destinataire des nouveaux leads (la boîte mail de l'équipe).
LEAD_NOTIFY_EMAIL=lionel@k-zamance.fr
# Expéditeur des emails de notif — DOIT être un sender validé dans Brevo.
LEAD_FROM_EMAIL=noreply@k-zamance.fr
LEAD_FROM_NAME=Leads K-zamance

# ─── Twenty CRM (stockage des leads des formulaires) ─────────────────────────
# URL racine de l'instance Twenty (Railway), sans /rest final.
# ex. https://crm.kzamance.fr  ou  https://twenty-production-xxxx.up.railway.app
TWENTY_BASE_URL=
# Clé API Twenty : Settings → APIs & Webhooks → Generate API Key (Bearer token).
TWENTY_API_KEY=
